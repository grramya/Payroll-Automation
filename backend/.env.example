# =============================================================================
# Copy this file to .env and fill in your values before running the app.
# Never commit .env to version control.
# =============================================================================

# ── Server ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security ───────────────────────────────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
PJE_SECRET_KEY=change-this-to-a-long-random-secret

# ── CORS ───────────────────────────────────────────────────────────────────────
# Development: list Vite dev server origins
# Production (Docker/nginx): add your server's domain, e.g. http://192.168.1.10
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ── QuickBooks Online OAuth 2.0 ────────────────────────────────────────────────
# Obtain from: https://developer.intuit.com → Your App → Keys & credentials
QBO_CLIENT_ID=your_qbo_client_id_here
QBO_CLIENT_SECRET=your_qbo_client_secret_here

# Set to true to use the QBO sandbox environment for testing
QBO_USE_SANDBOX=false
