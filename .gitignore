# ── Secrets — NEVER commit ─────────────────────────────────────────────────────
.env
*.env
!.env.example
backend/qbo/tokens.json

# ── Database ────────────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
venv/
.venv/
env/

# ── Node / Frontend build ──────────────────────────────────────────────────────
node_modules/
frontend/dist/
.vite/

# ── Runtime data (user-generated, not source) ──────────────────────────────────
backend/inputs/
backend/logs/
backend/JE/
backend/consolidated/
backend/cache/
backend/sessions/
*_output.xlsx

# ── QBO sidecar meta files (generated at runtime) ──────────────────────────────
backend/qbo/*.meta.json
backend/qbo/*.lock

# ── Debug / scratch files ───────────────────────────────────────────────────────
backend/*_debug.json
*_debug.json

# ── Mapping data files (contain client financial data) ─────────────────────────
"backend/Mapping table for FP&A_v5.xlsx"
backend/Mapping\ table\ for\ FP&A*.xlsx

# ── Temporary Excel lock files ─────────────────────────────────────────────────
~$*.xlsx

# ── Claude Code (local settings are machine-specific) ──────────────────────────
.claude/settings.local.json

# ── OS / editor ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
