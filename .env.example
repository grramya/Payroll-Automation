# =============================================================================
# .env.example — Copy this to backend/.env and fill in your values.
# The actual .env file is gitignored and must NEVER be committed.
# =============================================================================

# ── QuickBooks Online (Intuit Developer Portal) ────────────────────────────────
# Get these from https://developer.intuit.com → your app → Keys & credentials
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# OAuth redirect URI — must exactly match what you registered in the Dev Portal.
# Default works for local development; update for deployed environments.
QBO_REDIRECT_URI=http://localhost:8000/api/qbo/callback

# Company realm IDs — found in QBO under Gear → Your Account Information
QBO_MAIN_REALM_ID=
QBO_BROKER_REALM_ID=          # optional — leave blank if not using a broker company
QBO_BROKER_COMPANY_NAME=      # optional — display name for the broker company

# Set to "true" to point at the QBO sandbox instead of production
QBO_USE_SANDBOX=false

# ── App authentication (JWT) ───────────────────────────────────────────────────
# REQUIRED: Generate a strong random key — must be at least 32 bytes.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
PJE_SECRET_KEY=

# ── OAuth token encryption (REQUIRED) ────────────────────────────────────────
# The server will refuse to start if this is not set.
# QBO OAuth tokens (access + refresh) are stored in the database using Fernet
# symmetric encryption; without this key they cannot be stored securely.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Admin account ─────────────────────────────────────────────────────────────
# Password for the built-in "admin" user.
# On first run: if blank, a random UUID password is written to backend/admin_password.txt
# (NOT printed to logs). Set this env var to lock it to a known value.
PJE_ADMIN_PASSWORD=

# ── PostgreSQL connection ──────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_suite

# ── Cookie & HTTPS settings ───────────────────────────────────────────────────
# Set USE_HTTPS=true in production to add the Secure flag to the auth cookie.
# Set COOKIE_SAMESITE=strict for maximum CSRF protection (breaks OAuth redirects).
USE_HTTPS=false
COOKIE_SAMESITE=lax

# ── Gunicorn workers ──────────────────────────────────────────────────────────
# Requires PostgreSQL (not SQLite). Recommended: (2 × vCPUs) + 1
WORKERS=2

# ── AI chatbot ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── FP&A auto-refresh ─────────────────────────────────────────────────────────
# Time (local, HH:MM) at which the background daemon re-fetches QBO data daily
QBO_AUTO_FETCH_TIME=11:30
QBO_AUTO_FETCH_COMPANY_NAME=Concertiv
QBO_AUTO_FETCH_INCLUDE_BROKER=false

# ── Optional overrides ─────────────────────────────────────────────────────────
# ACCOUNTS_OVERRIDE_PATH=   # absolute path to a custom accounts_override.csv
# PJE_DATA_DIR=             # directory where session data is stored (default: backend/)
