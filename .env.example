# =============================================================================
# .env.example — Copy this to .env and fill in your values
# The actual .env file is gitignored and must never be committed.
# =============================================================================

# ── QuickBooks Online (Intuit Developer Portal) ────────────────────────────────
# Get these from https://developer.intuit.com → your app → Keys & credentials
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# OAuth redirect URI — must exactly match what you registered in the Dev Portal
# Default works for local development; update for deployed environments.
QBO_REDIRECT_URI=http://localhost:8000/api/qbo/callback

# Company realm IDs — found in QBO under Gear → Your Account Information
QBO_MAIN_REALM_ID=
QBO_BROKER_REALM_ID=          # optional — leave blank if not using broker company
QBO_BROKER_COMPANY_NAME=      # optional — display name for the broker company

# Set to "true" to point at the QBO sandbox instead of production
QBO_USE_SANDBOX=false

# ── App authentication (JWT) ───────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
PJE_SECRET_KEY=

# Admin password set on first run. If blank, a random password is printed to
# the server log on startup. Set this to lock it to a known value.
PJE_ADMIN_PASSWORD=

# ── Optional overrides ─────────────────────────────────────────────────────────
# Absolute path to a custom accounts_override.csv (defaults to qbo/accounts_override.csv)
# ACCOUNTS_OVERRIDE_PATH=

# Directory where auth.db is stored (defaults to backend/)
# PJE_DATA_DIR=
