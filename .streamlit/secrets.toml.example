# =============================================================================
# .streamlit/secrets.toml — Streamlit Community Cloud secrets template
# =============================================================================
# 1. On Streamlit Community Cloud: paste these into App Settings → Secrets
# 2. For local dev: copy this to .streamlit/secrets.toml and fill in values
#    (secrets.toml is in .gitignore — safe to fill in locally)
# =============================================================================

# ── QuickBooks Online credentials ─────────────────────────────────────────────
QBO_CLIENT_ID     = "your_client_id_here"
QBO_CLIENT_SECRET = "your_client_secret_here"

# ── QBO tokens (populated after first authentication) ─────────────────────────
# After connecting to QBO for the first time, the app shows a
# "Copy to Secrets" button. Paste the JSON string here so tokens
# survive server restarts on Streamlit Community Cloud.
# Example (replace with your real token JSON):
# QBO_TOKENS = '{"access_token":"...","refresh_token":"...","realm_id":"...","token_type":"Bearer","expires_at":0}'
QBO_TOKENS = ""

# ── Supabase (persistent activity log + JE file storage) ──────────────────────
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings → API → copy the URL and anon/public key
# 3. Run the setup SQL below in Supabase → SQL Editor
SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "your-anon-public-key-here"

# ── Supabase one-time setup ────────────────────────────────────────────────────
# A. Run this SQL in Supabase → SQL Editor (for activity logs):
#
# CREATE TABLE IF NOT EXISTS activity_log (
#     id             BIGSERIAL PRIMARY KEY,
#     timestamp      TEXT,
#     "user"         TEXT,
#     ip_address     TEXT,
#     hostname       TEXT,
#     action         TEXT,
#     input_file     TEXT,
#     output_file    TEXT,
#     journal_number TEXT,
#     details        TEXT,
#     changes_made   TEXT
# );
#
# B. Create a Storage bucket for JE files (for shared JE archive):
#    Supabase dashboard → Storage → New bucket
#    Name: je-files
#    Public: OFF  (private — only your app can access it)
